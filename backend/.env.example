ENV=development
CORS_ORIGINS=http://localhost:3000

# --- Storage backend ---
# memory  → InMemoryStore (default; tests, local dev)
# firestore → Google Cloud Firestore (Native mode); used in Cloud Run prod
STORE_BACKEND=memory
# Required when STORE_BACKEND=firestore. On Cloud Run this is auto-detected
# from the runtime; set explicitly for local dev (`gcloud auth application-default login`).
GCP_PROJECT_ID=

# --- Bolna Voice AI ---
# API key from https://platform.bolna.ai (Developers tab)
BOLNA_API_KEY=
# UUID of the agent that places the call (e.g. RTO Shield agent)
BOLNA_AGENT_ID=
# Bolna's API base URL (override only for staging mirrors)
BOLNA_API_BASE_URL=https://api.bolna.ai
# Leave blank on the trial plan (Bolna's default Plivo number is used).
# Set this only when you have purchased a dedicated Bolna number.
BOLNA_FROM_NUMBER=

# --- Demo overrides ---
# On Bolna trial plan, outbound calls only land on YOUR verified number.
# All "Verify" calls in the demo will be routed to this number,
# regardless of what the order record carries. Leave blank to disable override.
DEMO_RECIPIENT_NUMBER=

# Shared secret to weakly verify webhook origin in dev (optional).
# In production replace with HMAC signature validation.
BOLNA_WEBHOOK_SHARED_SECRET=
